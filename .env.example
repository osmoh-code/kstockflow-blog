# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google AdSense
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxx

# Google Analytics
NEXT_PUBLIC_GA_ID=G-xxxxx

# Google Search Console (for Indexing API)
# 1. Enable "Web Search Indexing API" in Google Cloud Console
# 2. Create a Service Account and download the JSON key
# 3. Add the service account email as owner in Google Search Console
# 4. Set the values below
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----"

# Thumbnail Image Search (Optional — at least one recommended)
# Unsplash: https://unsplash.com/developers (무료, 월 50회)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key
# Pixabay: https://pixabay.com/api/docs/ (무료, 월 5000회)
PIXABAY_API_KEY=your_pixabay_api_key

# Site
NEXT_PUBLIC_SITE_URL=https://kstockflow.com
